rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check
    function isAdmin(request) {
      return request.auth != null && request.auth.token.email == 'surajkp7@gmail.com';
    }

    // Players — anyone can read & create, only admin can update/delete
    match /players/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin(request);
    }

    // Groups — anyone can read, only admin can write
    match /groups/{id} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    // Matches — anyone can read, only admin can write
    match /matches/{id} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    // Tournament — anyone can read, only admin can write
    match /tournament/{id} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    // Admins — only admin can read/write
    match /admins/{id} {
      allow read, write: if isAdmin(request);
    }
  }
}
