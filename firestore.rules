rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower().replace('[^a-z0-9]', '_')));
    }

    function isDefaultAdmin() {
      return request.auth != null && request.auth.token.email.lower() == 'surajtxglive@gmail.com';
    }

    // Players — anyone can read & create, only admin can update/delete
    match /players/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasOnly(['name', 'efootballId', 'phone', 'status', 'group', 'registeredAt']) &&
        request.resource.data.name is string && request.resource.data.name.size() > 0 &&
        request.resource.data.efootballId is string && request.resource.data.efootballId.size() > 0 &&
        request.resource.data.status == 'pending' &&
        request.resource.data.group == null;
      allow update, delete: if isAdmin();
    }

    // Groups — anyone can read, only admin can write
    match /groups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Matches — anyone can read. Only admin can create/delete. Players
    // (unauthenticated) can: (1) submit their own team/manager setup text,
    // (2) submit their own report of the final score, and (3) trigger
    // auto-completion ONLY when the official score being written exactly
    // matches both players' already-stored reports. Every other field
    // (manual admin score entry, status changes outside this narrow path,
    // etc.) still requires isAdmin().
    match /matches/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['homeTeamSetup', 'awayTeamSetup', 'homeTeamSetupAt', 'awayTeamSetupAt']) ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['homeReportH', 'homeReportA', 'homeReportAt', 'awayReportH', 'awayReportA', 'awayReportAt', 'scoreMismatch']) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['homeScore', 'awayScore', 'status', 'winner']) &&
          'homeReportH' in resource.data && 'awayReportH' in resource.data &&
          resource.data.homeReportH == resource.data.awayReportH &&
          resource.data.homeReportA == resource.data.awayReportA &&
          request.resource.data.homeScore == resource.data.homeReportH &&
          request.resource.data.awayScore == resource.data.homeReportA &&
          request.resource.data.status == 'completed' &&
          ((request.resource.data.winner == 'home' && request.resource.data.homeScore > request.resource.data.awayScore) ||
           (request.resource.data.winner == 'away' && request.resource.data.awayScore > request.resource.data.homeScore) ||
           (request.resource.data.winner == 'draw' && request.resource.data.homeScore == request.resource.data.awayScore)));
    }

    // Tournament — anyone can read, only admin can write
    match /tournament/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins — the default admin (surajtxglive@gmail.com) is always visible to itself,
    // hidden from other admins' listings, and can never be removed. Only the default
    // admin can add or remove other admins.
    match /admins/{id} {
      allow read: if isAdmin() && (resource.data.isDefault == false || isDefaultAdmin());
      allow create: if isDefaultAdmin() &&
        request.resource.data.isDefault == false &&
        request.resource.data.keys().hasOnly(['email', 'addedAt', 'isDefault']);
      allow delete: if isDefaultAdmin() && resource.data.isDefault == false;
      allow update: if false;
    }

    // Activity log — anyone can read, anyone can create (for dispute logging), only admin can delete
    match /activity_log/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Disputes — anyone can read & create, only admin can update (resolve)
    match /disputes/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
